# PostgreSQL. Locally both point at the same DB.
# On Neon: DATABASE_URL = pooled (-pooler) connection, DIRECT_URL = direct connection.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kashio?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/kashio?schema=public"

# App
PORT=3000
API_PREFIX=v1

# Comma-separated allowed origins for CORS (e.g. your Vercel dashboard URL).
# Leave empty to allow any origin (fine for early testing).
CORS_ORIGINS=""

# JWT
JWT_SECRET="change-me-in-production"
ACCESS_TOKEN_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_DAYS="60"

# Google Sign-In: the OAuth "Web client ID" that issues the mobile idToken.
# The Flutter app must use this same value as GoogleSignIn(serverClientId: ...).
GOOGLE_CLIENT_ID="your-web-client-id.apps.googleusercontent.com"

# Seed admin credentials (used by prisma/seed.ts)
ADMIN_EMAIL="admin@kashio.app"
ADMIN_PASSWORD="admin123"
