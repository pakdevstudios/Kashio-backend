// Kashio delivery — Prisma schema
// Phase 1: Auth + Courier (parcel) module. Food & Pharmacy modules to follow.

generator client {
  provider = "prisma-client-js"
  // "native" for local dev, the rhel target for Vercel's Linux Lambda runtime.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  // Pooled connection (e.g. Neon -pooler host) used at runtime.
  url       = env("DATABASE_URL")
  // Direct connection used for migrations. Falls back to DATABASE_URL locally.
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  RIDER
  CUSTOMER
}

enum AuthProvider {
  PASSWORD
  GOOGLE
}

enum CourierStatus {
  PENDING // created, awaiting rider assignment
  ASSIGNED // admin assigned a rider, awaiting rider acceptance
  ACCEPTED // rider accepted the job
  PICKED_UP // parcel picked up
  ON_THE_WAY // en route to drop-off
  DELIVERED // completed
  CANCELLED // cancelled by admin/customer
  DRAFT // admin is still building the order (call in progress); not yet placed
}

enum ParcelWeight {
  UPTO_5KG
  UPTO_10KG
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}

enum ProductType {
  SIMPLE
  VARIABLE
}

enum VariationSelectionType {
  SINGLE
  MULTIPLE
}

model User {
  id        String       @id @default(uuid())
  email     String       @unique
  password  String? // null for Google-only accounts
  name      String
  phone     String?
  avatarUrl String?
  role      Role         @default(CUSTOMER)
  provider  AuthProvider @default(PASSWORD)
  googleId  String?      @unique
  isPremium Boolean      @default(false)
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  rider         Rider?
  couriers      Courier[]      @relation("CustomerCouriers")
  carts         Cart[]
  addresses     Address[]
  refreshTokens RefreshToken[]

  @@map("users")
}

// Opaque, rotating refresh tokens (stored hashed, never in plaintext).
model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  userAgent String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model Rider {
  id         String   @id @default(uuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  location   String?
  vehicle    String   @default("Bike")
  isAvailable Boolean @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  couriers Courier[] @relation("RiderCouriers")

  @@map("riders")
}

model Category {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@index([isActive])
  @@index([name])
  @@map("categories")
}

model Product {
  id                                String                 @id @default(uuid())
  title                             String
  slug                              String                 @unique
  description                       String?
  categoryId                        String
  category                          Category               @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  supplierId                        String?
  supplier                          Supplier?              @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  storeName                         String?
  productType                       ProductType            @default(VARIABLE)
  price                             Int
  discountedPrice                   Int?
  stockQuantity                     Int                    @default(0)
  variationLabel                    String                 @default("Variation")
  variationSelectionType            VariationSelectionType @default(SINGLE)
  isVariationRequired               Boolean                @default(true)
  minVariationSelections            Int                    @default(1)
  maxVariationSelections            Int                    @default(1)
  allowSpecialInstructions          Boolean                @default(false)
  specialInstructionsPlaceholder    String?
  specialInstructionsMaxLength      Int                    @default(250)
  isActive                          Boolean                @default(true)
  isAvailable                       Boolean                @default(true)
  createdAt                         DateTime               @default(now())
  updatedAt                         DateTime               @updatedAt

  images                    ProductImage[]
  variationOptions          ProductVariationOption[]
  frequentlyBoughtItems     ProductFrequentlyBoughtItem[] @relation("ProductFrequentlyBoughtSource")
  frequentlyBoughtOn        ProductFrequentlyBoughtItem[] @relation("ProductFrequentlyBoughtItem")
  cartItems                 CartItem[]
  cartAddOns                CartItemAddOn[]
  courierOrderItems         CourierOrderItem[]

  @@index([categoryId])
  @@index([supplierId])
  @@index([productType])
  @@index([isActive])
  @@index([isAvailable])
  @@index([price])
  @@index([title])
  @@map("products")
}

model Supplier {
  id            String         @id @default(uuid())
  name          String
  slug          String         @unique
  companyName   String?
  contactName   String?
  email         String?
  phone         String?
  address       String?
  city          String?
  notes         String?
  status        SupplierStatus @default(PENDING)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  products Product[]

  @@index([status])
  @@index([name])
  @@index([email])
  @@map("suppliers")
}

model Banner {
  id           String   @id @default(uuid())
  title        String
  imageUrl     String
  redirectUrl  String?
  targetType   String?
  targetId     String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive])
  @@index([displayOrder])
  @@index([title])
  @@map("banners")
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  altText   String?
  sortOrder Int      @default(0)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([isPrimary])
  @@map("product_images")
}

model ProductVariationOption {
  id            String   @id @default(uuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name          String
  sku           String?
  price         Int
  salePrice     Int?
  stockQuantity Int      @default(0)
  isActive      Boolean  @default(true)
  isDefault     Boolean  @default(false)
  minQuantity   Int      @default(1)
  maxQuantity   Int      @default(99)
  displayOrder  Int      @default(0)
  imageUrl      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  cartItems          CartItem[]
  cartItemVariations CartItemVariation[]
  cartAddOns         CartItemAddOn[]
  courierOrderItems  CourierOrderItem[]

  @@index([productId])
  @@index([productId, isActive])
  @@index([productId, displayOrder])
  @@map("product_variation_options")
}

model ProductFrequentlyBoughtItem {
  id               String  @id @default(uuid())
  productId        String
  product          Product @relation("ProductFrequentlyBoughtSource", fields: [productId], references: [id], onDelete: Cascade)
  relatedProductId String
  relatedProduct   Product @relation("ProductFrequentlyBoughtItem", fields: [relatedProductId], references: [id], onDelete: Restrict)
  isDefault        Boolean @default(false)
  isActive         Boolean @default(true)
  minQuantity      Int     @default(1)
  maxQuantity      Int     @default(99)
  displayOrder     Int     @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([productId, relatedProductId])
  @@index([productId])
  @@index([relatedProductId])
  @@index([productId, isActive])
  @@map("product_frequently_bought_items")
}

model Cart {
  id        String     @id @default(uuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([userId])
  @@index([userId])
  @@map("carts")
}

model CartItem {
  id                  String                  @id @default(uuid())
  cartId              String
  cart                Cart                    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId           String
  product             Product                 @relation(fields: [productId], references: [id], onDelete: Restrict)
  variationOptionId   String?
  variationOption     ProductVariationOption? @relation(fields: [variationOptionId], references: [id], onDelete: Restrict)
  quantity            Int
  unitPrice           Int?
  specialInstructions String?
  configKey           String
  selectedVariations  CartItemVariation[]
  addOns              CartItemAddOn[]
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  @@unique([cartId, configKey])
  @@index([cartId])
  @@index([productId])
  @@index([variationOptionId])
  @@map("cart_items")
}

model CartItemVariation {
  id                String                 @id @default(uuid())
  cartItemId        String
  cartItem          CartItem               @relation(fields: [cartItemId], references: [id], onDelete: Cascade)
  variationOptionId String
  variationOption   ProductVariationOption @relation(fields: [variationOptionId], references: [id], onDelete: Restrict)
  quantity          Int
  unitPrice         Int
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@index([cartItemId])
  @@index([variationOptionId])
  @@map("cart_item_variations")
}

model CartItemAddOn {
  id                String                  @id @default(uuid())
  cartItemId        String
  cartItem          CartItem                @relation(fields: [cartItemId], references: [id], onDelete: Cascade)
  productId         String
  product           Product                 @relation(fields: [productId], references: [id], onDelete: Restrict)
  variationOptionId String?
  variationOption   ProductVariationOption? @relation(fields: [variationOptionId], references: [id], onDelete: Restrict)
  quantity          Int
  unitPrice         Int
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@index([cartItemId])
  @@index([productId])
  @@index([variationOptionId])
  @@map("cart_item_add_ons")
}

model Address {
  id                   String   @id @default(uuid())
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName             String
  phone                String
  addressLine          String
  city                 String
  stateProvince        String
  country              String
  postalCode           String
  deliveryInstructions String?
  isDefault            Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([userId])
  @@index([userId, isDefault])
  @@map("addresses")
}

model Courier {
  id        String        @id @default(uuid())
  code      String        @unique // human-friendly e.g. DLV-1042
  status    CourierStatus @default(PENDING)

  // What's being delivered
  categories String[] // e.g. ["Documents", "Food"]
  weight     ParcelWeight @default(UPTO_5KG)
  notes      String?
  price      Int          @default(0) // in minor units / rupees

  // Pickup
  pickupName    String
  pickupContact String
  pickupAddress String
  pickupLat     Float?
  pickupLng     Float?

  // Drop-off
  dropName    String
  dropContact String
  dropAddress String
  dropLat     Float?
  dropLng     Float?

  // Relations
  customerId String?
  customer   User?   @relation("CustomerCouriers", fields: [customerId], references: [id], onDelete: SetNull)
  riderId    String?
  rider      Rider?  @relation("RiderCouriers", fields: [riderId], references: [id], onDelete: SetNull)
  orderItems CourierOrderItem[]

  // Lifecycle timestamps
  assignedAt    DateTime?
  acceptedAt    DateTime?
  pickedUpAt    DateTime?
  deliveredAt   DateTime?
  cancelledAt   DateTime?
  cancelReason  String?

  events    CourierEvent[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([riderId])
  @@map("couriers")
}

model CourierOrderItem {
  id                String                  @id @default(uuid())
  courierId         String
  courier           Courier                 @relation(fields: [courierId], references: [id], onDelete: Cascade)
  productId         String
  product           Product                 @relation(fields: [productId], references: [id], onDelete: Restrict)
  variationOptionId String?
  variationOption   ProductVariationOption? @relation(fields: [variationOptionId], references: [id], onDelete: Restrict)
  productName       String
  selectedVariant   String?
  price             Int
  quantity          Int
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@index([courierId])
  @@index([productId])
  @@index([variationOptionId])
  @@map("courier_order_items")
}

// Status history / tracking timeline for a courier booking.
model CourierEvent {
  id        String        @id @default(uuid())
  courierId String
  courier   Courier       @relation(fields: [courierId], references: [id], onDelete: Cascade)
  status    CourierStatus
  note      String?
  createdAt DateTime      @default(now())

  @@index([courierId])
  @@map("courier_events")
}
